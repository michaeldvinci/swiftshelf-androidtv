# Example environment variables for testing against live deployments
# Copy this file to .env and fill in your actual values
# .env is gitignored and won't be committed

# HTTP endpoint (e.g., local dev server)
export TEST_HTTP_URL="http://192.168.1.100:13378/"

# HTTPS endpoint (e.g., production server)
export TEST_HTTPS_URL="https://audiobookshelf.example.com/"

# Credentials (same for both HTTP and HTTPS)
export TEST_USERNAME="your-username"
export TEST_PASSWORD="your-password"

# Java Home (required for Gradle on macOS)
export JAVA_HOME=/opt/homebrew/opt/openjdk@17/libexec/openjdk.jdk/Contents/Home

# Usage:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your actual values
# 3. Source it: source .env
# 4. Run tests: ./gradlew testDebugUnitTest --tests "com.swiftshelf.RealEndpointAuthTest.*"
